# FraudCase AI local config template. Mock mode requires no cloud credentials.
USE_MOCKS=true

# --- MongoDB Atlas (optional live mode) ---
# ATLAS_URI=mongodb+srv://user:password@cluster.example.mongodb.net/?retryWrites=true&w=majority
DB_NAME=fraudcase_ai

# --- Google Cloud / Vertex AI (optional live mode) ---
# GCP_PROJECT=your-gcp-project-id
GCP_REGION=us-central1
GEMINI_MODEL=gemini-3.1-pro-preview
GEMINI_LOCATION=global
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMS=768

# Use Vertex AI for Gemini calls, not the public Gemini Developer API.
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Optional live-mode service-account key path. Never commit a real key.
# GOOGLE_APPLICATION_CREDENTIALS=./fraudcase-gcp-key.json
