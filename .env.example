# FraudCase AI local config template. Mock mode requires no cloud credentials.
USE_MOCKS=true

# --- UiPath Automation Cloud (live mode) ---
# External application (client credentials) used to call UiPath APIs.
# UIPATH_OAUTH_TOKEN_URL=https://cloud.uipath.com/identity_/connect/token
# UIPATH_CLIENT_ID=your-external-app-client-id
# UIPATH_CLIENT_SECRET=your-external-app-client-secret
# UIPATH_SCOPE=

# --- UiPath Data Service (system of record) ---
# Generated entity endpoints differ per tenant/folder/region.
# UIPATH_DATASERVICE_TRANSACTIONS_URL=
# UIPATH_DATASERVICE_VENDORS_URL=
# UIPATH_DATASERVICE_POLICIES_URL=
# UIPATH_DATASERVICE_AUDIT_LOG_URL=

# --- UiPath Context Grounding (embeddings, vector index, retrieval) ---
# API Workflow / HTTP endpoint that queries the Context Grounding index.
# UIPATH_CONTEXT_GROUNDING_QUERY_URL=
UIPATH_CONTEXT_GROUNDING_INDEX_NAME=fraudcase-ai-evidence
